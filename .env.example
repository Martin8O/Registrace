# Supabase needs BOTH connection strings and they are not interchangeable:
#   DATABASE_URL — POOLED (pgBouncer, port 6543). Used by the app at runtime.
#   DIRECT_URL   — DIRECT (port 5432). Used by Prisma migrate / seed / the promote
#                  script; migrations cannot run over the pooler.
# Supabase → Project Settings → Database → Connection string.
DATABASE_URL=""
DIRECT_URL=""

# Supabase → Project Settings → API. The anon key is used for AUTH ONLY — no data
# is ever read through it (all data access goes via Prisma on the server).
# NEXT_PUBLIC_* is inlined at BUILD time: it must be set before the build runs.
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# Service-role key — SERVER ONLY, never exposed to the browser. Used for admin
# user management (invite / reset / delete auth users).
SUPABASE_SERVICE_ROLE_KEY=""

# Resend API key — confirmation emails. Sending failure is non-blocking: it never
# rolls back a registration.
RESEND_API_KEY=""
# REQUIRED. The app's own origin. Used for Supabase invite/reset links AND the
# admin CSRF Origin/Referer check (P4) — in production a mutating admin request
# whose Origin doesn't match this is rejected 403, so an unset/wrong value here
# silently 403s every admin write. Must be the real deployed origin in prod
# (set per-env on Vercel; NEXT_PUBLIC_* is inlined at BUILD time).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# Verified Resend sender. Runtime value — changing it needs a redeploy.
# e.g. "BDC Registrace <noreply@send.example.com>"
EMAIL_FROM=""
# The "owner" account(s) — only an owner may create / modify / (via demote-then-
# delete) remove SUPER_ADMINs; other super-admins manage ADMINs only and cannot
# touch each other. Empty/unset (both vars) → no owner → nobody can manage
# super-admins (fail-closed). Two sources:
#   OWNER_USER_IDS  — PREFERRED. Comma-separated Supabase Auth user UUIDs. A user
#                     id is immutable, so this can't be spoofed by changing an
#                     email. Find the id in Supabase → Authentication → Users.
#   OWNER_EMAILS    — legacy fallback, comma-separated (case-insensitive). Honoured
#                     ONLY for a VERIFIED email (an email is user-changeable on the
#                     profile page). Prefer OWNER_USER_IDS in production.
# Set here AND on Vercel.
OWNER_USER_IDS=""
OWNER_EMAILS=""

# OPTIONAL — tooling only, not read by the app. Fallback address for
# `prisma/promote-super-admin.ts` when it is run without an argument.
SUPER_ADMIN_EMAIL=""
