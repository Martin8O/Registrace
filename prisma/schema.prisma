generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum AgeCategory {
  AGE_0_3
  AGE_4_7
  AGE_8_14
  AGE_15_PLUS
}

enum PricingType {
  STANDARD
  SUPPORTED
  SURPLUS
}

enum ArrivalTime {
  MORNING
  AFTERNOON
  EVENING
}

enum EarlyDeparture {
  NONE
  AFTER_BREAKFAST
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

enum MealType {
  BREAKFAST
  LUNCH
  DINNER
}

// Diet choice per participant for the meals they order (mirrors the real BDC
// form's "masité / vegetariánské"). Default MEAT keeps the additive migration
// safe for pre-existing rows + any old client still inserting; the form/Zod make
// it an explicit required choice for new registrations.
enum MealCategory {
  MEAT
  VEGETARIAN
}

enum RegistrationStatus {
  REGISTERED
  CANCELLED
  PAID
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
}

model User {
  id        String   @id @db.Uuid
  email     String   @unique
  role      UserRole @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs     AuditLog[]
  centers       UserCenter[]
  createdEvents Event[]

  @@index([email])
}

model UserCenter {
  id       String @id @default(cuid())
  userId   String @db.Uuid
  centerId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  center Center @relation(fields: [centerId], references: [id])
  @@unique([userId, centerId])
  @@index([userId])
}

model Center {
  id        String   @id @default(cuid())
  name_cs   String
  name_en   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  registrations Registration[]
  admins        UserCenter[]
  events        Event[]
}

model Event {
  id               String      @id @default(cuid())
  title_cs         String
  title_en         String
  subtitle_cs      String?
  subtitle_en      String?
  description_cs   String?
  description_en   String?
  contactName      String?
  contactPhone     String?
  contactEmail     String?
  status           EventStatus @default(DRAFT)
  maxRegistrations Int?
  centerId         String
  startDate        DateTime
  endDate          DateTime
  createdBy        String?     @db.Uuid
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deletedAt        DateTime?
  // Optional cut-off after which meals can no longer be ordered for this event
  // (participation/accommodation stay open). Stored UTC; entered/displayed as
  // Europe/Prague wall-clock (invariant 11 — handles SELČ/SEČ automatically).
  mealRegistrationDeadline DateTime?
  // Human-readable registration-number support. `numberPrefix` = frozen YYEEE
  // (event's year + its per-year ordinal, e.g. "26002"); `registrationSeq` is an
  // atomically-incremented per-event registrant counter. A registration's full
  // number = numberPrefix + 4-digit seq (e.g. "260020108"). Nullable to allow
  // the additive migration; backfilled for pre-existing events, set at creation
  // for new ones.
  numberPrefix     String?     @unique
  registrationSeq  Int         @default(0)

  creator          User?             @relation(fields: [createdBy], references: [id])
  center           Center            @relation(fields: [centerId], references: [id])
  dates            EventDate[]
  pricingRules     PricingRule[]
  mealPricingRules MealPricingRule[]
  meals            EventMeal[]
  registrations    Registration[]

  @@index([status])
  @@index([startDate])
  @@index([createdBy])
  @@index([centerId])
}

model EventDate {
  id        String   @id @default(cuid())
  eventId   String
  date      DateTime
  label_cs  String
  label_en  String
  sortOrder Int      @default(0)

  event          Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  mealSlots      EventMeal[]
  arrivalDates   Registration[] @relation("ArrivalDate")
  departureDates Registration[] @relation("DepartureDate")

  @@index([eventId])
}

// Participation price list: one row per age category × pricing tier. Since M37
// the tier applies to EVERY age (children included), so a fully-configured event
// carries 4 × 3 = 12 rows; events created before that carry only the 3 child
// STANDARD rows + the three 15+ tiers and were backfilled (see the migration).
model PricingRule {
  id                       String      @id @default(cuid())
  eventId                  String
  ageCategory              AgeCategory
  pricingType              PricingType @default(STANDARD)
  dailyRate                Int         @default(0)
  nightRate                Int         @default(0)
  morningArrivalDiscount   Int         @default(0)
  afternoonArrivalDiscount Int         @default(0)
  eveningArrivalDiscount   Int         @default(0)
  earlyDepartureDiscount   Int         @default(0)
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, ageCategory, pricingType])
  @@index([eventId])
}

// Meal price list: one row per meal type × age category × pricing tier (3 × 4 × 3
// = 36 rows per fully-configured event), set once for the whole event. Introduced
// in M37 — before it, a meal cost the same for everybody (the flat EventMeal.price),
// which could not express "a child's lunch is cheaper" or a supported/surplus tier.
//
// Deliberately keyed by mealType and NOT by eventMealId: the price list is a
// property of the event, not of a single day's slot. Every event in the database
// already charged one price per meal type across all its days when this was added,
// so per-day price variation was a capability nobody used — modelling it here would
// have multiplied the rows by the day count and the admin form by the same factor.
// Per-day control that IS used (include/exclude a slot) stays on EventMeal.
model MealPricingRule {
  id          String      @id @default(cuid())
  eventId     String
  mealType    MealType
  ageCategory AgeCategory
  pricingType PricingType @default(STANDARD)
  price       Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)

  @@unique([eventId, mealType, ageCategory, pricingType])
  @@index([eventId])
}

model EventMeal {
  id          String   @id @default(cuid())
  eventId     String
  eventDateId String
  mealType    MealType
  // LEGACY headline price, kept in sync with the 15+/STANDARD MealPricingRule row.
  // The engine prices a meal from MealPricingRule and only falls back to this when
  // an event has no price list at all (invariant 21). Retained rather than dropped
  // because ParticipantMeal rows and the deployed client both still read it —
  // expand-and-contract, same as Participant.mealType in M31.
  price       Int      @default(0)
  isClosed    Boolean  @default(false)
  label_cs    String
  label_en    String

  event            Event             @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventDate        EventDate         @relation(fields: [eventDateId], references: [id], onDelete: Cascade)
  participantMeals ParticipantMeal[]

  @@unique([eventDateId, mealType])
  @@index([eventId])
}

model Registration {
  id                 String             @id @default(cuid())
  eventId            String
  centerId           String
  arrivalDateId      String
  arrivalTime        ArrivalTime
  departureDateId    String
  earlyDeparture     EarlyDeparture     @default(NONE)
  hasAccommodation   Boolean            @default(false)
  email              String
  gdprConsent        Boolean            @default(false)
  totalPrice         Int                @default(0)
  status             RegistrationStatus @default(REGISTERED)
  idempotencyKey     String?            @unique
  confirmationSentAt DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  deletedAt          DateTime?
  // GDPR (P8 item 8): the submitter's IP, captured server-side from request
  // headers at submit. Retained ONLY for abuse prevention / rate-limiting
  // (legitimate-interest basis) — never surfaced in the UI or any export, and
  // not part of the public submit payload. See lib/validation/registrations.ts.
  ipAddress          String?
  // Human-readable, unique registration number shown to registrants + searched
  // by the on-site team (e.g. "260020108" = year 26 / event 002 / registrant 0108).
  // Assigned at submit from the event's numberPrefix + registrationSeq. Nullable
  // only for the additive migration; backfilled for existing rows, always set on
  // new ones.
  registrationNumber String?            @unique
  // UI locale the visitor registered in ("cs"/"en"); drives the confirmation
  // email language at submit AND on later admin resend (P6). Default "cs" keeps
  // pre-P6 rows valid. Plain String, not an enum, mirroring the `"cs"|"en"`
  // union used throughout the app.
  locale             String             @default("cs")

  event         Event         @relation(fields: [eventId], references: [id])
  center        Center        @relation(fields: [centerId], references: [id])
  arrivalDate   EventDate     @relation("ArrivalDate", fields: [arrivalDateId], references: [id])
  departureDate EventDate     @relation("DepartureDate", fields: [departureDateId], references: [id])
  participants  Participant[]

  @@index([eventId])
  @@index([email])
  @@index([createdAt])
}

model Participant {
  id                 String      @id @default(cuid())
  registrationId     String
  fullName           String
  ageCategory        AgeCategory
  pricingType        PricingType @default(STANDARD)
  // Diet for this participant's ordered meals. Default MEAT for migration safety;
  // the form/Zod require an explicit choice on new registrations.
  mealType           MealCategory @default(MEAT)
  participationPrice Int         @default(0)
  mealPrice          Int         @default(0)
  totalPrice         Int         @default(0)
  sortOrder          Int         @default(0)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  deletedAt          DateTime?

  registration Registration      @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  meals        ParticipantMeal[]

  @@index([registrationId])
}

model ParticipantMeal {
  id            String @id @default(cuid())
  participantId String
  eventMealId   String
  price         Int    @default(0)

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  eventMeal   EventMeal   @relation(fields: [eventMealId], references: [id])

  @@unique([participantId, eventMealId])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  @db.Uuid
  action     String
  entityType String
  entityId   String
  oldData    Json?
  newData    Json?
  ip         String? // client IP of the actor (P4) — forensic trail; nullable for non-HTTP/system writes
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([entityType, entityId])
  @@index([createdAt])
}
